rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated or projectId
    // Fields:
    //   - teamName: string (required)
    //   - zoneId: string (required)
    //   - ownerId: string (required, immutable)
    //   - members: list of objects (optional)
    //   - milestones: list of objects (optional)
    //   - menu: list of objects (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['teamName', 'zoneId', 'ownerId', 'createdAt']) &&
             data.teamName is string && data.teamName.size() > 0 && data.teamName.size() < 100 &&
             data.zoneId is string &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isDocOwner() && 
                      isValidProject(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
