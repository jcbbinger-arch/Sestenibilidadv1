rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated or projectId
    // Fields:
    //   - teamName: string (required)
    //   - zoneId: string (required)
    //   - ownerId: string (required, immutable)
    //   - members: list of objects (optional)
    //   - milestones: list of objects (optional)
    //   - menu: list of objects (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         request.auth.token.email == 'managerproapp@gmail.com' ||
         request.auth.token.email == 'jcbbinger@gmail.com');
    }

    function isApproved() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved' || isAdmin());
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['teamName', 'zoneId', 'ownerId', 'createdAt']) &&
             data.teamName is string && data.teamName.size() > 0 && data.teamName.size() < 100 &&
             data.zoneId is string &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidProject(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && 
                      isValidProject(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
